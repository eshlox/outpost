# Trusted SSH signing keys, for verifying commit/tag signatures locally
# (`git log --show-signature`). Referenced by gpg.ssh.allowedSignersFile when you
# enable signing in local.gitconfig. Format: <principal> [options] <keytype> <key>.
# These are PUBLIC keys - safe to commit. Add a line per identity you want to verify:
#
# you@example.com namespaces="git" ssh-ed25519 AAAA...your-public-key...
